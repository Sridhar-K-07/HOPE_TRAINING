class Solution {
    public int majorityElement(int[] nums) {
        Map<Integer, Integer> map = new HashMap<>();
        int max = 0;
        int ans = nums[0];
        for (int i : nums) {
            map.put(i, map.getOrDefault(i, 0) + 1);
        }

        for (int i = 0; i < nums.length; i++) {
            if (max < map.get(nums[i])) {
                max = map.get(nums[i]);
                ans=nums[i];
               
            }
        }

        return ans;
    }
}