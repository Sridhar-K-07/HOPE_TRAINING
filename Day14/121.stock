class Solution {
    public int maxProfit(int[] prices) {
        int l=prices.length;
        int maxi=0; int d=0;
        int min=Integer.MAX_VALUE;
        for(int i:prices){
            if(min>=i){
                min=i;
            }
            else{
               d=i-min;
               maxi=Math.max(d,maxi); 
            }
        }

        return maxi;
    }
}